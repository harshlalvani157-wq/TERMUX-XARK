prefix=/root/xodos/xodosark-audio/out/pulse-android-prefix
exec_prefix=/root/xodos/xodosark-audio/out/pulse-android-prefix
libdir=/root/xodos/xodosark-audio/out/pulse-android-prefix/lib
includedir=/root/xodos/xodosark-audio/out/pulse-android-prefix/include

Name: libpulse-simple
Description: PulseAudio Simplified Synchronous Client Interface
Version: 17.0-dirty
Libs: -L${libdir} -lpulse-simple -pthread
Libs.private: -L${libdir}/pulseaudio -lpulsecommon-17.0
Cflags: -I${includedir} -D_REENTRANT
Requires: libpulse
