# Copy this file to keystore.properties (DO NOT commit keystore.properties).
# Generate a keystore once, e.g. from xodosark-app/:
#   keytool -genkey -v -keystore release.keystore -alias xodosark -keyalg RSA -keysize 2048 -validity 10000
#
# Paths are relative to the xodosark-app/ directory (same folder as this file).

storeFile=release.keystore
storePassword=change-me
keyAlias=xodosark
keyPassword=change-me
